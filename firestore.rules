rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User profiles
    match /users/{uid} {
      function isValidUser(data) {
        return data.uid is string && 
               data.email is string && 
               data.uid == request.auth.uid;
      }
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidUser(incoming());
      allow update: if isOwner(uid) && isValidUser(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    // Chat Sessions
    match /sessions/{sessionId} {
      function isValidSession(data) {
        return data.userId == request.auth.uid &&
               data.assistantType in ['astra', 'lumina'] &&
               data.title is string && data.title.size() <= 100;
      }
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidSession(incoming());
      allow update: if isOwner(existing().userId) && 
                      (incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt', 'lastMessage', 'title']));
      allow delete: if isOwner(existing().userId);
      
      // Messages Subcollection
      match /messages/{messageId} {
        function isValidMessage(data) {
          return data.senderId is string &&
                 data.senderType in ['user', 'assistant'] &&
                 data.content is string && data.content.size() <= 10000;
        }
        allow list: if isSignedIn() && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
        allow get: if isSignedIn() && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
        allow create: if isSignedIn() && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid && isValidMessage(incoming());
        allow update: if isSignedIn() && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['feedback']);
      }
    }
  }
}
